# Vercel KV / Redis
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Upstash Redis REST API is also supported
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Self-hosted Redis, for Docker or local server deployment
REDIS_URL=redis://localhost:6379

# Optional site name. This changes the global title, buttons, and link preview title.
NEXT_PUBLIC_SITE_NAME=阅后即焚
NEXT_PUBLIC_APP_VERSION=1.0.1

# Optional site URL used by README examples. Runtime links are generated from the request origin.
NEXT_PUBLIC_SITE_URL=

# Docker-only web updater. deploy-docker.sh writes these values automatically.
YUEHOU_DOCKER_UPDATE_ENABLED=false
YUEHOU_HOST_PROJECT_DIR=/opt/yuehou
YUEHOU_UPDATE_TOKEN=
YUEHOU_UPDATE_VERSION_URL=https://raw.githubusercontent.com/hmbbser/yuehou1/main/package.json
